==========================================
Simple Dockerfile (Beginner)
==========================================
# This is base image for python

FROM python:3.11 

WORKDIR /app                         # current working directory inside container

RUN pip install -r requirements.txt  # build and install dependencies 

COPY . .                             # copy from dockerfile from current folder to working directory inside container

EXPOSE 2000                          # optional 

CMD [ "python", "app.py" ]           # command that run when container start


